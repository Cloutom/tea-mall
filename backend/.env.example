# 서버 설정
NODE_ENV=development
PORT=4000

# 데이터베이스 (AWS RDS PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@your-rds-endpoint.ap-northeast-2.rds.amazonaws.com:5432/tea_mall?schema=public"

# JWT 시크릿
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-token-secret
JWT_REFRESH_EXPIRES_IN=30d

# AWS S3 (이미지 업로드)
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=tea-mall-images

# 카카오 OAuth
KAKAO_CLIENT_ID=your-kakao-client-id
KAKAO_REDIRECT_URI=http://localhost:4000/api/auth/kakao/callback

# 구글 OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# 네이버 OAuth
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret
NAVER_REDIRECT_URI=http://localhost:4000/api/auth/naver/callback

# 토스페이먼츠
TOSS_SECRET_KEY=your-toss-secret-key
TOSS_CLIENT_KEY=your-toss-client-key

# 공공데이터 사업자 등록번호 조회 API
BIZNO_API_KEY=your-bizno-api-key

# 이메일 (알림)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# 클라이언트 URL
CLIENT_URL=http://localhost:3000
SELLER_CLIENT_URL=http://localhost:3001
